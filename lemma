from math import gcd
from collections import Counter


def get_partitions(n, i=1):
    """
    Generate integer partitions of n in non-decreasing order.
    Corresponds to conjugacy classes of S_n.
    """
    yield [n]
    for x in range(i, n // 2 + 1):
        for p in get_partitions(n - x, x):
            yield [x] + p


def factorial_table_upto(n):
    """Precompute factorials for conjugacy class size calculations."""
    fact = [1] * (n + 1)
    for i in range(1, n + 1):
        fact[i] = fact[i - 1] * i
    return fact


def permutation_class_size(partition, n, fact):
    """
    Size of conjugacy class in S_n:
    |S_n| / (∏ k^{m_k} * m_k!)
    """
    counts = Counter(partition)

    denom = 1
    for cycle_len, multiplicity in counts.items():
        denom *= (cycle_len ** multiplicity) * fact[multiplicity]

    return fact[n] // denom


def grid_cycle_kernel(row_cycles, col_cycles):
    """
    Pairwise cycle interaction kernel.

    IMPORTANT CLARIFICATION:
    This computes the sum of cycle-pair contributions:
        gcd(r, c)

    This is a valid local orbit contribution for a single (r, c) cycle pair,
    but is NOT, by itself, a full proof of global cycle-index factorization.

    It is used here as a modeling assumption consistent with product-action structure.
    """
    total = 0
    for r in row_cycles:
        for c in col_cycles:
            total += gcd(r, c)
    return total


def solution(w, h, s):
    """
    Burnside-style enumeration over S_w × S_h using:
    - partition-based conjugacy class grouping
    - class size weighting
    - cycle-pair interaction kernel (gcd-based)

    NOTE:
    This is a structured compression of the full permutation action.
    """
    max_val = max(w, h)
    fact = factorial_table_upto(max_val)

    total = 0

    for row_partition in get_partitions(h):
        row_weight = permutation_class_size(row_partition, h, fact)

        for col_partition in get_partitions(w):
            col_weight = permutation_class_size(col_partition, w, fact)

            exponent = grid_cycle_kernel(row_partition, col_partition)

            total += row_weight * col_weight * (s ** exponent)

    return str(total // (fact[w] * fact[h]))


# sanity check
print(solution(2, 2, 2))  # "7"
