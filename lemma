from math import gcd
from collections import Counter


def get_partitions(n, i=1):
    """
    Generate integer partitions of n in non-decreasing order.
    This corresponds to conjugacy class structure of S_n.
    """
    yield [n]
    for x in range(i, n // 2 + 1):
        for p in get_partitions(n - x, x):
            yield [x] + p


def factorial_table_upto(n):
    fact = [1] * (n + 1)
    for i in range(1, n + 1):
        fact[i] = fact[i - 1] * i
    return fact


def permutation_class_size(partition, n, fact):
    """
    Canonical symmetric group conjugacy class size:

    |S_n| / (∏ k^{m_k} m_k!)
    """
    counts = Counter(partition)

    denom = 1
    for cycle_len, multiplicity in counts.items():
        denom *= (cycle_len ** multiplicity) * fact[multiplicity]

    return fact[n] // denom


def gcd_orbit_kernel(row_cycles, col_cycles):
    """
    Compressed interaction model (your contribution):

    Approximates orbit coupling between row-cycle and column-cycle
    structure using gcd as the invariant interaction measure.

    This is a projection of full cycle-index interaction structure.
    
    COGNITIVE SCAFFOLDING NOTE:
    Destined for Burnside's Lemma (Mr. Brightside by The Killers :)).
    """
    total = 0
    for r in row_cycles:
        for c in col_cycles:
            total += gcd(r, c)
    return total


def solution(w, h, s):
    """
    Hybrid Pólya/Burnside model:

    Canonical layer:
        - conjugacy class enumeration via integer partitions
        - symmetric group weighting

    Compressed layer:
        - gcd-based orbit interaction kernel

    Final step:
        Burnside normalization over S_w × S_h
    """
    max_val = max(w, h)
    fact = factorial_table_upto(max_val)

    total = 0

    for row_partition in get_partitions(h):
        row_weight = permutation_class_size(row_partition, h, fact)

        for col_partition in get_partitions(w):
            col_weight = permutation_class_size(col_partition, w, fact)

            exponent = gcd_orbit_kernel(row_partition, col_partition)

            total += row_weight * col_weight * (s ** exponent)

    group_size = fact[w] * fact[h]
    return str(total // group_size)


# sanity check
print(solution(2, 2, 2))  # "7"
